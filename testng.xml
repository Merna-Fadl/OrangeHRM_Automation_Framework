<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Full Regression Suite" parallel="none" thread-count="2">

    <listeners>
        <listener class-name="Utils.TestListener" />
    </listeners>

    <test name="Regression Tests - Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.PIMTest"/>
            <class name="tests.RecruitmentTest"/>
            <class name="tests.AdminTests"/>
            <class name="tests.LoginNegativeTests"/>
        </classes>
    </test>

    <test name="Regression Tests - Edge">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.PIMTest"/>
            <class name="tests.RecruitmentTest"/>
            <class name="tests.AdminTests"/>
            <class name="tests.LoginNegativeTests"/>
        </classes>
    </test>



</suite>